#!/usr/bin/env bash
# oneshot-dispatch
#
# Ships a prepared dispatch bundle to a remote Oneshot server and starts
# a sandbox container to run it. The companion to the (future) discuss-agent
# seal step.
#
# Responsibilities:
#   1. Validate the bundle directory has the expected files
#   2. Rsync the bundle to $VOLUME_ROOT/runs/$RUN_ID/bundle/ on the server
#   3. Start a container via `docker run` with:
#        - volume mount for the run artifacts (status.jsonl, heartbeats.jsonl,
#          current.json, agent.log)
#        - volume mount for the bundle (read-only)
#        - CPU / memory / GPU limits from CLI or profile
#        - env vars for the run id and model
#   4. Emit `dispatched` (local) and `received` (server) events
#   5. Print the run_id and a `oneshot-status` command to follow along
#
# This script is shell-only by design — no premature CJS/Python layer.
# When the framework grows a proper orchestrator, this logic gets wrapped.
#
# Required on the operator's machine: bash 4+, ssh, rsync, jq
# Required on the server: docker, bash, git
#
# See DESIGN.md §3 (Dispatcher) and §"Storage Topology".

set -euo pipefail

usage() {
  cat <<'EOF'
Usage: oneshot-dispatch [options] <bundle_dir>

Required:
  --host <hostname>          SSH target (e.g. user@host, or hostname)

Optional:
  --run-id <id>              Run identifier (default: r-YYYYMMDD-HHMMSS)
  --volume-root <path>       Server-side volume root (default: ~/oneshot-data)
  --image <name:tag>         Sandbox image (default: oneshot-sandbox:latest)
  --runtime <cmd>            Container runtime on server (default: podman)
  --repo-path <path>         Local path to the target git repo. If set,
                             rsyncs the working copy to the server and
                             mounts it at /workspace/repo (writable) as
                             the agent's working directory. If unset,
                             the bundle directory is used as-is (only
                             useful for smoke tests).
  --cpu <n>                  CPU limit (default: 4)
  --memory <size>            Memory limit (default: 8g)
  --gpu                      Request GPU passthrough
  --local-run-dir <path>     Local run dir; if set, dispatched event is
                             written to <path>/status.jsonl
  --dry-run                  Print what would happen, don't execute
  -h, --help                 Show this help

The bundle_dir must contain at least:
  requirements.md
  project.md

See DESIGN.md §3 (Dispatcher) for the full bundle contract.
EOF
}

HOST=""
RUN_ID=""
VOLUME_ROOT="~/oneshot-data"
IMAGE="oneshot-sandbox:latest"
RUNTIME="podman"
REPO_PATH=""
CPU="4"
MEMORY="8g"
GPU_FLAGS=""
LOCAL_RUN_DIR=""
DRY_RUN=0
BUNDLE_DIR=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --host)          HOST="$2"; shift 2 ;;
    --run-id)        RUN_ID="$2"; shift 2 ;;
    --volume-root)   VOLUME_ROOT="$2"; shift 2 ;;
    --image)         IMAGE="$2"; shift 2 ;;
    --runtime)       RUNTIME="$2"; shift 2 ;;
    --repo-path)     REPO_PATH="$2"; shift 2 ;;
    --cpu)           CPU="$2"; shift 2 ;;
    --memory)        MEMORY="$2"; shift 2 ;;
    --gpu)           GPU_FLAGS="--gpus all"; shift ;;
    --local-run-dir) LOCAL_RUN_DIR="$2"; shift 2 ;;
    --dry-run)       DRY_RUN=1; shift ;;
    -h|--help)       usage; exit 0 ;;
    --)              shift; BUNDLE_DIR="$1"; shift ;;
    -*)
      echo "error: unknown flag: $1" >&2
      usage >&2
      exit 2
      ;;
    *)
      if [[ -z "$BUNDLE_DIR" ]]; then
        BUNDLE_DIR="$1"
      else
        echo "error: unexpected positional arg: $1" >&2
        exit 2
      fi
      shift
      ;;
  esac
done

require() {
  if [[ -z "${!1}" ]]; then
    echo "error: $1 is required" >&2
    usage >&2
    exit 2
  fi
}

require HOST
if [[ -z "$BUNDLE_DIR" ]]; then
  echo "error: bundle_dir argument is required" >&2
  usage >&2
  exit 2
fi

if [[ ! -d "$BUNDLE_DIR" ]]; then
  echo "error: bundle_dir not found: $BUNDLE_DIR" >&2
  exit 1
fi

# Validate bundle structure.
missing=()
for f in requirements.md project.md; do
  if [[ ! -f "$BUNDLE_DIR/$f" ]]; then
    missing+=("$f")
  fi
done
if [[ ${#missing[@]} -gt 0 ]]; then
  echo "error: bundle is missing required files:" >&2
  printf '  %s\n' "${missing[@]}" >&2
  exit 1
fi

# Derive run id if not provided.
if [[ -z "$RUN_ID" ]]; then
  RUN_ID="r-$(date -u +%Y%m%d-%H%M%S)"
fi

log() { printf '[dispatch] %s\n' "$*"; }
iso_now() { date -u +"%Y-%m-%dT%H:%M:%SZ"; }

# Resolve VOLUME_ROOT to an absolute path on the remote (expands ~ on the server).
if [[ $DRY_RUN -eq 0 ]]; then
  VOLUME_ROOT_ABS="$(ssh "$HOST" "echo $VOLUME_ROOT")"
else
  VOLUME_ROOT_ABS="$VOLUME_ROOT"
fi

REMOTE_RUN_DIR="$VOLUME_ROOT_ABS/runs/$RUN_ID"
REMOTE_BUNDLE_DIR="$REMOTE_RUN_DIR/bundle"
REMOTE_REPO_DIR="$REMOTE_RUN_DIR/repo"

log "run_id:      $RUN_ID"
log "host:        $HOST"
log "runtime:     $RUNTIME"
log "image:       $IMAGE"
log "cpu/memory:  $CPU / $MEMORY"
[[ -n "$GPU_FLAGS" ]] && log "gpu:         yes"
log "bundle:      $BUNDLE_DIR"
[[ -n "$REPO_PATH" ]] && log "repo:        $REPO_PATH"
log "remote dir:  $REMOTE_RUN_DIR"

# Build resource limit flags. Rootless Podman on cgroups v2 may not have cpu/memory
# controllers delegated — in that case, skip limits and log a note.
RESOURCE_FLAGS=""
if [[ "$CPU" != "0" && "$CPU" != "none" ]]; then
  RESOURCE_FLAGS="--cpus=$CPU"
fi
if [[ "$MEMORY" != "0" && "$MEMORY" != "none" ]]; then
  RESOURCE_FLAGS="$RESOURCE_FLAGS --memory=$MEMORY"
fi

# 1. Prepare remote run directory.
log "preparing remote run directory"
if [[ $DRY_RUN -eq 1 ]]; then
  echo "  DRY: ssh $HOST mkdir -p $REMOTE_RUN_DIR/bundle $REMOTE_RUN_DIR/repo"
else
  ssh "$HOST" "mkdir -p '$REMOTE_RUN_DIR' '$REMOTE_BUNDLE_DIR' '$REMOTE_REPO_DIR'"
fi

# 2. Ship bundle via rsync.
log "shipping bundle via rsync"
if [[ $DRY_RUN -eq 1 ]]; then
  echo "  DRY: rsync $BUNDLE_DIR/ → $HOST:$REMOTE_BUNDLE_DIR/"
else
  rsync -az --delete "$BUNDLE_DIR/" "$HOST:$REMOTE_BUNDLE_DIR/"
fi

# 3. Ship repo working copy (if --repo-path was provided).
# Excludes target/, node_modules/ etc. to keep the copy lean. The agent will
# work against this copy; changes persist on the server after the run.
if [[ -n "$REPO_PATH" ]]; then
  if [[ ! -d "$REPO_PATH" ]]; then
    echo "error: --repo-path directory not found: $REPO_PATH" >&2
    exit 1
  fi
  log "shipping repo working copy via rsync"
  if [[ $DRY_RUN -eq 1 ]]; then
    echo "  DRY: rsync $REPO_PATH/ → $HOST:$REMOTE_REPO_DIR/"
  else
    rsync -az --delete \
      --exclude 'target/' \
      --exclude 'node_modules/' \
      --exclude '.venv/' \
      --exclude 'dist/' \
      --exclude 'build/' \
      --exclude '*.pyc' \
      "$REPO_PATH/" "$HOST:$REMOTE_REPO_DIR/"
  fi
fi

# 3. Emit `dispatched` event locally (if a local run dir was provided).
if [[ -n "$LOCAL_RUN_DIR" && $DRY_RUN -eq 0 ]]; then
  mkdir -p "$LOCAL_RUN_DIR"
  local_status="$LOCAL_RUN_DIR/status.jsonl"
  gpu_bool="false"
  [[ -n "$GPU_FLAGS" ]] && gpu_bool="true"
  dispatched_event=$(jq -nc \
    --arg ts "$(iso_now)" \
    --arg run_id "$RUN_ID" \
    --arg host "$HOST" \
    --arg cpu "$CPU" \
    --arg memory "$MEMORY" \
    --argjson gpu "$gpu_bool" \
    '{ts:$ts,type:"dispatched",run_id:$run_id,host:$host,container_spec:{cpu:$cpu,memory:$memory,gpu:$gpu}}')
  printf '%s\n' "$dispatched_event" >> "$local_status"
  log "emitted dispatched → $local_status"
fi

# 4. Start the container on the server.
log "starting sandbox container on $HOST"

# Podman SELinux note: :Z relabels the volume for container access (needed on
# SELinux-enforcing hosts like Rocky/RHEL). Harmless on non-SELinux systems.
# Build env var flags.
ENV_FLAGS="-e ONESHOT_RUN_ID=$RUN_ID"
ENV_FLAGS="$ENV_FLAGS -e ONESHOT_MODEL=${ONESHOT_MODEL:-claude-opus-4-6}"
ENV_FLAGS="$ENV_FLAGS -e ONESHOT_HEARTBEAT_INTERVAL_S=${ONESHOT_HEARTBEAT_INTERVAL_S:-30}"
if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
  ENV_FLAGS="$ENV_FLAGS -e ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY"
fi
if [[ -n "${ONESHOT_BUDGET_USD:-}" ]]; then
  ENV_FLAGS="$ENV_FLAGS -e ONESHOT_BUDGET_USD=$ONESHOT_BUDGET_USD"
fi

# Resolve git identity from the operator's local env so commits made by the
# sandbox agent are attributed to the human, not a synthetic localhost user.
# Falls back to GIT_AUTHOR_NAME/EMAIL env vars if git config isn't set.
#
# Values may contain spaces (e.g. "Victor Ferreira") so they must be
# shell-escaped with printf %q before being concatenated into the container
# command — otherwise word-splitting breaks the `podman run` invocation.
GIT_NAME="${GIT_AUTHOR_NAME:-$(git config --global user.name 2>/dev/null || true)}"
GIT_EMAIL="${GIT_AUTHOR_EMAIL:-$(git config --global user.email 2>/dev/null || true)}"
if [[ -n "$GIT_NAME" ]]; then
  ENV_FLAGS="$ENV_FLAGS -e ONESHOT_GIT_NAME=$(printf '%q' "$GIT_NAME")"
  log "git identity: $GIT_NAME <$GIT_EMAIL>"
fi
if [[ -n "$GIT_EMAIL" ]]; then
  ENV_FLAGS="$ENV_FLAGS -e ONESHOT_GIT_EMAIL=$(printf '%q' "$GIT_EMAIL")"
fi

# Auth mounts: pass operator's credential directories from the server user
# into the container so the agent can authenticate against Claude + GitHub
# without dispatcher-managed secrets.
#
# Claude Code auth   (~/.claude/):           OAuth session for subscription
# GitHub CLI auth    (~/.config/gh/):        git push + gh pr create
#
# Both are mounted read-write under the non-root 'oneshot' user's home in
# the container. The host UID maps to the container UID via --userns=keep-id,
# so these are the operator's own files either way.
REMOTE_HOME="$(ssh "$HOST" 'echo $HOME')"
CLAUDE_MOUNT="-v ${REMOTE_HOME}/.claude:/home/oneshot/.claude:Z"
log "auth mount:  ${REMOTE_HOME}/.claude → /home/oneshot/.claude (claude, rw)"

# GitHub CLI auth — check if the server user has a gh config directory
# before mounting. Skip with a warning if not (smoke tests don't need it;
# real PR-opening tasks do).
GH_MOUNT=""
if ssh "$HOST" "[[ -d ${REMOTE_HOME}/.config/gh ]]" 2>/dev/null; then
  GH_MOUNT="-v ${REMOTE_HOME}/.config/gh:/home/oneshot/.config/gh:Z"
  log "auth mount:  ${REMOTE_HOME}/.config/gh → /home/oneshot/.config/gh (github, rw)"
else
  log "auth mount:  NO gh config found on server — agent cannot push/PR"
  log "             run: ssh -t $HOST 'gh auth login' (if gh installed)"
fi

# User namespace mapping. Claude Code refuses --dangerously-skip-permissions
# as root, so the container runs as a non-root 'oneshot' user (UID 1000).
# For Podman: --userns=keep-id maps container UID 1000 to the host user's UID
# directly, so mounted volumes have transparent permissions. For Docker:
# --user 1000:1000 achieves a similar effect when host UID is 1000.
if [[ "$RUNTIME" == "podman" ]]; then
  USERNS_FLAG="--userns=keep-id"
else
  USERNS_FLAG="--user 1000:1000"
fi

# Mount strategy:
#   /workspace/run   — whole run directory (status.jsonl, heartbeats.jsonl,
#                      bundle/, repo/, etc.). Read-write.
#   /workspace/repo  — if --repo-path was set: the rsynced repo working copy,
#                      read-write so the agent can edit, commit, push.
#                      Otherwise: falls back to the bundle dir (smoke test mode).
#
# The agent reads the requirements from /workspace/run/bundle/requirements.md
# and works in /workspace/repo.
if [[ -n "$REPO_PATH" ]]; then
  REPO_MOUNT="-v $REMOTE_REPO_DIR:/workspace/repo:Z"
else
  REPO_MOUNT="-v $REMOTE_BUNDLE_DIR:/workspace/repo:Z"
fi

container_cmd="$RUNTIME run -d \
  --name oneshot-$RUN_ID \
  $USERNS_FLAG \
  $RESOURCE_FLAGS \
  $GPU_FLAGS \
  $CLAUDE_MOUNT \
  $GH_MOUNT \
  -v $REMOTE_RUN_DIR:/workspace/run:Z \
  $REPO_MOUNT \
  $ENV_FLAGS \
  $IMAGE"

if [[ $DRY_RUN -eq 1 ]]; then
  echo "  DRY: ssh '$HOST' '$container_cmd'"
  container_id="dry-run-fake-id"
else
  container_id="$(ssh "$HOST" "$container_cmd")"
  log "container id: $container_id"

  # 5. Emit `received` event on the server's status.jsonl.
  received_event=$(jq -nc --arg ts "$(iso_now)" --arg cid "$container_id" \
    '{ts:$ts,type:"received",container_id:$cid}')
  ssh "$HOST" "printf '%s\n' '$received_event' >> $REMOTE_RUN_DIR/status.jsonl"
fi

log "dispatched $RUN_ID"
log ""
log "follow progress with:"
log "  oneshot-status '$HOST' '$REMOTE_RUN_DIR'"
log ""
log "stream logs with:"
log "  ssh '$HOST' tail -f '$REMOTE_RUN_DIR/agent.log'"
